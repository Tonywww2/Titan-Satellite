{
  "sea_level": 12,
  "disable_mob_generation": false,
  "aquifers_enabled": false,
  "ore_veins_enabled": false,
  "legacy_random_source": false,
  "default_block": { "Name": "titan_moon:titan_stone" },
  "default_fluid": { "Name": "titan_moon:liquid_methane", "Properties": { "level": "0" } },
  "noise": {
    "min_y": 0,
    "height": 320,
    "size_horizontal": 1,
    "size_vertical": 1
  },
  "noise_router": {
    "barrier": 0,
    "fluid_level_floodedness": 0,
    "fluid_level_spread": 0,
    "lava": 0,
    "temperature": {
      "type": "minecraft:shifted_noise",
      "noise": "minecraft:temperature",
      "shift_x": "minecraft:shift_x",
      "shift_y": 0.0,
      "shift_z": "minecraft:shift_z",
      "xz_scale": 0.2,
      "y_scale": 0.0
    },
    "vegetation": "titan_moon:climate/vegetation",
    "continents": "titan_moon:climate/continents",
    "erosion": "titan_moon:climate/erosion",
    "depth": 0,
    "ridges": "titan_moon:climate/ridges",
    "initial_density_without_jaggedness": 0,
    "final_density": "titan_moon:titan_final_density",
    "vein_toggle": 0,
    "vein_ridged": 0,
    "vein_gap": 0
  },
  "surface_rule": {
    "type": "minecraft:sequence",
    "sequence": [
      {
        "_comment": "主世界式基岩底：世界最底部(min_y=0)向上 0-4 格锯齿状基岩——Y0 必为基岩，Y5 起绝不为基岩。底部地形已由 cave/caves 的 y<4 +4 偏置保证实心，故无空洞。",
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:vertical_gradient",
          "random_name": "minecraft:bedrock_floor",
          "true_at_and_below": { "above_bottom": 0 },
          "false_at_and_above": { "above_bottom": 5 }
        },
        "then_run": { "type": "minecraft:block", "result_state": { "Name": "minecraft:bedrock" } }
      },
      {
        "_comment": "托林沙海 硬化托林 带状+区域生成(表面露头)：由 minecraft:surface 噪声门控成片区域，在这些区域内表层(surface 起 depth 0-3)直接是 hardened_tholin 结壳——排在通用表层规则之前故盖过 tholin_sand、露于地表；非门控区仍为沙。区域密度调 noise_threshold.min_threshold(越低越广)，结壳厚度调 stone_depth.offset。",
        "type": "minecraft:condition",
        "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:tholin_dune_sea"] },
        "then_run": {
          "type": "minecraft:condition",
          "if_true": { "type": "minecraft:noise_threshold", "noise": "minecraft:surface", "min_threshold": 0.25, "max_threshold": 2.0 },
          "then_run": {
            "type": "minecraft:condition",
            "if_true": { "type": "minecraft:stone_depth", "offset": 3, "surface_type": "floor", "add_surface_depth": false, "secondary_depth_range": 0 },
            "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:hardened_tholin" } }
          }
        }
      },
      {
        "type": "minecraft:condition",
        "if_true": {
          "type": "minecraft:stone_depth",
          "offset": 0,
          "surface_type": "floor",
          "add_surface_depth": true,
          "secondary_depth_range": 0
        },
        "then_run": {
          "type": "minecraft:sequence",
          "sequence": [
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:methane_abyss"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:sedimentary_titan_stone" } } },
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:cratered_wastelands"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:weathered_titan_stone" } } },
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:tholin_dune_sea"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:tholin_sand" } } },
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:polar_labyrinth"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:packed_methane_ice" } } },
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:cryovolcanic_cliff"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:cryo_ice" } } },
            { "type": "minecraft:condition", "if_true": { "type": "minecraft:biome", "biome_is": ["titan_moon:barren_plateau"] }, "then_run": { "type": "minecraft:block", "result_state": { "Name": "titan_moon:weathered_titan_stone" } } },
            { "type": "minecraft:block", "result_state": { "Name": "titan_moon:tholin_sand" } }
          ]
        }
      }
    ]
  },
  "spawn_target": []
}
