# Normalize line endings: store as LF in the repo, check out per-platform
* text=auto

# Windows batch scripts must keep CRLF
*.bat text eol=crlf

# Unix shell scripts (incl. Gradle wrapper) must keep LF
*.sh text eol=lf
gradlew text eol=lf

# Binary assets — never touch line endings
*.jar binary
*.png binary
*.ogg binary
*.nbt binary
*.dat binary
